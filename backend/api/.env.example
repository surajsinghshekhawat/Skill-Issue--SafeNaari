# Copy to .env and fill in values. Never commit .env.

PORT=3001
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_TIMEOUT=120000

# Google Cloud — enable Places, Geocoding, Routes API (+ Maps SDK for mobile tiles is separate)
GOOGLE_MAPS_API_KEY=

# Twilio SMS (optional for panic SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# JWT for mobile users (use a long random string in production)
USER_JWT_SECRET=change-me-to-a-long-random-string

# Require Bearer token for mobile report/panic/location routes when true
MOBILE_AUTH_REQUIRED=false

# Postgres (optional — API runs with in-memory/file fallbacks if unset)
# If password contains @, URL-encode it as %40
DATABASE_URL=
